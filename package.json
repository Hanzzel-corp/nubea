{
  "name": "nubea-browser",
  "version": "0.1.3",
  "description": "Nubea - navegador simple sin historial por diseño",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:linux",
    "build:linux": "electron-builder --linux --publish=never",
    "build:appimage": "electron-builder --linux AppImage --publish=never",
    "build:deb": "electron-builder --linux deb --publish=never",
    "dist": "electron-builder --publish=never"
  },
  "keywords": [
    "browser",
    "no-history",
    "privacy",
    "electron",
    "nubea"
  ],
  "author": {
    "name": "Hanzzel Corp",
    "email": "zamorajose03@gmail.com"
  },
  "license": "MIT",
  "type": "commonjs",
  "homepage": "https://github.com/Hanzzel-corp/nubea-browser",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hanzzel-corp/nubea-browser.git"
  },
  "bugs": {
    "url": "https://github.com/Hanzzel-corp/nubea-browser/issues"
  },
  "build": {
    "appId": "com.hanzzel.nubea",
    "productName": "Nubea",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network",
      "icon": "build/icon.png",
      "maintainer": "Hanzzel Corp <zamorajose03@gmail.com>"
    }
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^25.0.0"
  }
}
